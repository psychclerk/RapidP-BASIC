$TYPECHECK ON

DIM A(10) AS INTEGER
DIM B(1 TO 5) AS STRING

A(0) = 42
A(10) = 99

B(1) = "Hello"
B(5) = "World"

PRINT "A(0) = ", A(0)
PRINT "A(10) = ", A(10)
PRINT "B(1) = ", B(1)
PRINT "B(5) = ", B(5)

' We need to pass function calls correctly when array indexing is ambiguous!
' Oh wait, Python lists are 0-indexed! B(1 TO 5) in RapidP gets translated to Python `[None] * 5` which is 0-indexed!
' In RapidP if I define DIM B(1 TO 5), B(1) maps to index 0...
