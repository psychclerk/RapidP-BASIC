$TYPECHECK ON

CONST MAX_TICKS = 3

DIM ticks AS INTEGER
ticks = 0

CREATE MainForm AS PForm
    Caption = "Exhaustive RapidP Demo"
    Width = 500
    Height = 400
    
    CREATE MainPanel AS PPanel
        Left = 10
        Top = 10
        Width = 480
        Height = 100
        
        CREATE TypeLabel AS PLabel
            Caption = "Choose type:"
            Left = 10
            Top = 15
        END CREATE
        
        CREATE TypeCombo AS PComboBox
            Left = 100
            Top = 10
            Width = 150
            AddItems("String", "Integer", "Double")
        END CREATE
        
        CREATE Check1 AS PCheckBox
            Caption = "Enable Logging"
            Left = 300
            Top = 10
            OnClick = OnEnableLoginClick
        END CREATE
        
    END CREATE
    
    CREATE DataGrid AS PStringGrid
        Left = 10
        Top = 120
        Width = 480
        Height = 200
    END CREATE
    
    CREATE AutoTimer AS PTimer
        Interval = 500
        Enabled = vtTrue
    END CREATE

END CREATE

SUB OnEnableLoginClick()
    If Check1.Checked = 1 THEN
        PRINT "Enable Login Clicked"
    ELSE
        PRINT "Disable Login Clicked"
    END IF
END SUB

SUB OnTick()
    PRINT "Timer tick: ", ticks
    ticks = ticks + 1
    IF ticks >= MAX_TICKS THEN
        REM MainForm.Close()
    END IF
END SUB

AutoTimer.OnTimer = OnTick
Check1.Checked = vtTrue
TypeCombo.Text = "String"

PRINT "Starting Application"
PRINT "Hex of 255 is: ", HEX$(255)

MainForm.ShowModal()
PRINT "Application Closed."
