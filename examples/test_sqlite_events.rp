' Test: PSQLite database component with events
' Tests connect, query, events, and data retrieval

DIM ConnectFired AS INTEGER
DIM QueryFired AS INTEGER
DIM DisconnectFired AS INTEGER
ConnectFired = 0
QueryFired = 0
DisconnectFired = 0

SUB OnDBConnect
    ConnectFired = 1
    PRINT "PASS: OnConnect event fired"
END SUB

SUB OnDBQueryDone
    QueryFired = 1
    PRINT "PASS: OnQueryDone event fired"
END SUB

SUB OnDBDisconnect
    DisconnectFired = 1
    PRINT "PASS: OnDisconnect event fired"
END SUB

SUB OnDBError(ErrMsg AS STRING)
    PRINT "ERROR: " + ErrMsg
END SUB

DIM DB AS PSQLITE

DB.OnConnect = OnDBConnect
DB.OnQueryDone = OnDBQueryDone
DB.OnDisconnect = OnDBDisconnect
DB.OnError = OnDBError

' Connect to in-memory database
PRINT "Connecting to in-memory SQLite..."
DB.Connect(":memory:")

IF DB.Connected = 1 THEN
    PRINT "PASS: Connected to SQLite"
ELSE
    PRINT "FAIL: Not connected"
END IF

IF ConnectFired = 1 THEN
    PRINT "PASS: OnConnect callback confirmed"
ELSE
    PRINT "FAIL: OnConnect not fired"
END IF

' Create a table
DB.Query("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, age INTEGER)")
PRINT "PASS: Table created"

' Insert data
DB.Query("INSERT INTO users VALUES (1, 'Alice', 30)")
DB.Query("INSERT INTO users VALUES (2, 'Bob', 25)")
DB.Query("INSERT INTO users VALUES (3, 'Charlie', 35)")
PRINT "PASS: Data inserted"

' Query data
DB.Query("SELECT * FROM users ORDER BY id")

IF DB.RowCount = 3 THEN
    PRINT "PASS: RowCount = 3"
ELSE
    PRINT "FAIL: RowCount = " + STR$(DB.RowCount)
END IF

IF DB.ColCount = 3 THEN
    PRINT "PASS: ColCount = 3"
ELSE
    PRINT "FAIL: ColCount = " + STR$(DB.ColCount)
END IF

IF QueryFired = 1 THEN
    PRINT "PASS: OnQueryDone callback confirmed"
ELSE
    PRINT "FAIL: OnQueryDone not fired"
END IF

' Fetch rows
DB.FetchRow
PRINT "Row 1: " + DB.Row(1) + ", age " + DB.Row(2)

DB.FetchRow
PRINT "Row 2: " + DB.Row(1) + ", age " + DB.Row(2)

DB.FetchRow
PRINT "Row 3: " + DB.Row(1) + ", age " + DB.Row(2)

' Close
DB.Close

IF DisconnectFired = 1 THEN
    PRINT "PASS: OnDisconnect callback confirmed"
ELSE
    PRINT "FAIL: OnDisconnect not fired"
END IF

PRINT ""
PRINT "All SQLite tests completed!"
