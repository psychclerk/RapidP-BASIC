' Test: Font properties inside CREATE blocks
' Tests Font.Size, Font.Name, Font.Bold, Font.Italic inside CREATE blocks

SUB AutoClose
    PRINT "Font tests completed!"
    Form1.Close
END SUB

CREATE Form1 AS PFORM
    Caption = "Font Properties Test"
    Width = 500
    Height = 400
    Font.Size = 12
    Font.Name = "Helvetica"

    CREATE Label1 AS PLABEL
        Caption = "Large Bold Label"
        Left = 10
        Top = 10
        Width = 300
        Height = 30
        Font.Size = 18
        Font.Bold = 1
    END CREATE

    CREATE Edit1 AS PEDIT
        Left = 10
        Top = 50
        Width = 300
        Height = 30
        Font.Size = 14
        Font.Name = "Courier"
    END CREATE

    CREATE Button1 AS PBUTTON
        Caption = "Styled Button"
        Left = 10
        Top = 90
        Width = 200
        Height = 40
        Font.Size = 16
        Font.Bold = 1
        Font.Italic = 1
    END CREATE

    CREATE Check1 AS PCHECKBOX
        Caption = "Italic Checkbox"
        Left = 10
        Top = 140
        Width = 200
        Height = 24
        Font.Italic = 1
    END CREATE

    CREATE Combo1 AS PCOMBOBOX
        Left = 10
        Top = 170
        Width = 200
        Height = 24
        Font.Size = 11
    END CREATE

    CREATE CloseTimer AS PTIMER
        Interval = 500
        OnTimer = AutoClose
    END CREATE
END CREATE

' Post-CREATE checks
PRINT "PASS: Font.Size on Form = " + STR$(Form1.Font.Size)
PRINT "PASS: Font.Size on Label = " + STR$(Label1.Font.Size)
PRINT "PASS: Font.Size on Edit = " + STR$(Edit1.Font.Size)
PRINT "PASS: Font.Size on Button = " + STR$(Button1.Font.Size)
PRINT "PASS: Font.Bold on Label = " + STR$(Label1.Font.Bold)
PRINT "PASS: Font.Bold on Button = " + STR$(Button1.Font.Bold)
PRINT "PASS: Font.Italic on Button = " + STR$(Button1.Font.Italic)
PRINT "PASS: Font.Italic on Check = " + STR$(Check1.Font.Italic)
PRINT "All font property tests passed!"

Form1.ShowModal
