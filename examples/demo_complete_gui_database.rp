        Top = 200
    END CREATE
    
    CREATE CloseAboutBtn AS PBUTTON
        Caption = "OK"
        Left = 160
        Top = 230
        Width = 80
        OnClick = OnCloseAbout
    END CREATE
END CREATE

' ============================================================================
' INITIALIZATION
' ============================================================================

' Populate department combo box
DeptComboBox.AddItems "IT", "HR", "Sales", "Finance", "Marketing", "Operations"

' Initialize StringGrid with headers
StatsGrid.Cells(0, 0) = "Statistic"
StatsGrid.Cells(1, 0) = "Value"
StatsGrid.Cells(0, 1) = "Total Employees"
StatsGrid.Cells(0, 2) = "Departments"
StatsGrid.Cells(0, 3) = "Active"

PRINT "Starting RapidP Complete Database Demo..."
PRINT "This demo showcases:"
PRINT "- ListView with multiple columns"
PRINT "- ComboBox, CheckBox, Edit controls"
PRINT "- TabControl with multiple tabs"
PRINT "- StringGrid for displaying tabular data"
PRINT "- Multi-window support (modal dialogs)"
PRINT "- Full CRUD database operations"
PRINT "- Event handling for all controls"
PRINT ""

MainForm.ShowModal

PRINT "Application closed."
