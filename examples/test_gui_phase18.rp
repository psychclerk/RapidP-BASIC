$TYPECHECK ON

PRINT "Creating dummy UI..."

CREATE Form AS PForm
    Width = 300
    Height = 200
    Caption = "Phase 18 Integration"
    
    CREATE Bar AS PProgressBar
        Top = 10
        Left = 10
        Width = 200
        Position = 50
    END CREATE
    
    CREATE View AS PListView
        Top = 40
        Left = 10
        Width = 200
        Height = 100
    END CREATE
    
    CREATE HTMLView AS PHTML
        Top = 150
        Left = 10
        Width = 200
        Height = 40
    END CREATE
END CREATE

DIM OpenDlg AS POpenDialog
DIM WebSock AS PSocket

PRINT "App Instantiated Successfully."
Form.ShowModal
