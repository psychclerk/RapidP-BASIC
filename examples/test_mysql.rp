$TYPECHECK ON

DIM MySQL AS PMYSQL

PRINT "Attempting to Connect to Localhost MySQL..."
IF MySQL.Connect("localhost", "rqdevtest", "DeV%Tes1T$", "rapidpdevtestdb") THEN
    PRINT "Connected Successfully! Showing DBs:"
    DIM I AS INTEGER
    FOR I = 0 TO MySQL.DBCount - 1
        PRINT "DB: " + MySQL.DB(I)
    NEXT
    
    PRINT "Creating Test Table..."
    MySQL.Query("CREATE TABLE IF NOT EXISTS user_metrics (id INT AUTO_INCREMENT PRIMARY KEY, username VARCHAR(50), login_count INT);")
    MySQL.Query("INSERT INTO user_metrics (username, login_count) VALUES ('roanbema', 42);")
    
    PRINT "Fetching Data..."
    MySQL.Query("SELECT * FROM user_metrics")
    
    WHILE MySQL.FetchRow
        PRINT "Row ID: " + MySQL.Row(0) + " User: " + MySQL.Row(1) + " Logins: " + MySQL.Row(2)
    WEND
    MySQL.Close
ELSE
    PRINT "Failed to Connect to MySQL"
END IF
