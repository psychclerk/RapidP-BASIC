        Left = 422 : Top = 4 : Width = 52 : Height = 26
        OnClick = SetToolList
    END CREATE
    CREATE BtnAddGroup AS PBUTTON
        Caption = "⎕ Grp"
        Left = 476 : Top = 4 : Width = 50 : Height = 26
        OnClick = SetToolGroup
    END CREATE

    ' --- Row 2: Advanced controls ---
    CREATE BtnAddProgress AS PBUTTON
        Caption = "█ Prog"
        Left = 4 : Top = 32 : Width = 52 : Height = 26
        OnClick = SetToolProgress
    END CREATE
    CREATE BtnAddTimer AS PBUTTON
        Caption = "⏱ Tmr"
        Left = 58 : Top = 32 : Width = 48 : Height = 26
        OnClick = SetToolTimer
    END CREATE
    CREATE BtnAddRichEdit AS PBUTTON
        Caption = "≣ Rich"
        Left = 108 : Top = 32 : Width = 52 : Height = 26
