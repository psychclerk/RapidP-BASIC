    ' === Action Buttons ===
    CREATE ActionPanel AS PPANEL
        Left = 790 : Top = 0
        Width = 300 : Height = 90
    END CREATE

    CREATE BtnDelete AS PBUTTON
        Caption = "❌ Del"
        Left = 794 : Top = 4 : Width = 52 : Height = 26
        OnClick = DeleteSelected
