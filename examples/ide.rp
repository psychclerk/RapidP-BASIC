        Caption = "▶ Run"
        Left = 908 : Top = 4 : Width = 52 : Height = 26
        OnClick = CompileAndRun
    END CREATE
    CREATE BtnCode AS PBUTTON
        Caption = "⌨ Code"
        Left = 964 : Top = 4 : Width = 56 : Height = 26
        OnClick = ToggleCodeView
    END CREATE
    CREATE BtnStandalone AS PBUTTON
        Caption = "📦 Build"
        Left = 794 : Top = 32 : Width = 64 : Height = 26
        OnClick = BuildStandalone
    END CREATE

    ' === Left Panel: Object Combo + Properties/Events ===
    CREATE ObjCombo AS PCOMBOBOX
        Left = 4 : Top = 94
        Width = 252 : Height = 24
        OnChange = ObjComboChange
    END CREATE

    CREATE PropEvtTabs AS PTABCONTROL
        Left = 4 : Top = 122
        Width = 252 : Height = 630
    END CREATE

    CREATE PropGrid AS PSTRINGGRID
        Left = 0 : Top = 0
        Width = 244 : Height = 590
        Visible = 0
        OnChange = PropGridChange
    END CREATE

    CREATE EvtGrid AS PSTRINGGRID
        Left = 0 : Top = 0
        Width = 244 : Height = 590
        Visible = 0
        OnChange = EvtGridChange
        OnDblClick = EvtGridDblClick
    END CREATE

    ' === Code Editor (hidden in design mode) ===
    CREATE CodeEditor AS PCODEEDITOR
        Left = 264 : Top = 94
        Width = 820 : Height = 610
        Visible = 0
    END CREATE

    ' === Error List (hidden by default) ===
    CREATE ErrorList AS PLISTBOX
        Left = 264 : Top = 710
        Width = 820 : Height = 50
        Visible = 0
        OnClick = ErrorListClick
    END CREATE

    ' === Status Bar ===
    CREATE StatusBar AS PLABEL
        Left = 0 : Top = 768
        Width = 1100 : Height = 20
        Caption = "Ready - RapidP Visual IDE"
    END CREATE
END CREATE

' === Design Surface (separate Toplevel) ===
CREATE DesignSurface AS PDESIGNSURFACE
    Width = 640
    Height = 480
    FormCaption = "Form1"
    OnSelect = DesignSelect
    OnMove = DesignMove
    OnDblClick = DesignDblClick
    OnBgClick = DesignBgClick
END CREATE

' === Post-CREATE initialization ===
PropEvtTabs.AddTabs("Properties", "Events")
PropGrid.Parent = PropEvtTabs.Tab(0)
EvtGrid.Parent = PropEvtTabs.Tab(1)
PropGrid.Visible = 1
EvtGrid.Visible = 1
PropGrid.Cols = 2
EvtGrid.Cols = 2
ObjCombo.AddItems("Form1")
FillProperties
FillEvents

DesignSurface.Show
IDE.ShowModal
