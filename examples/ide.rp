' ============================================================
' HELPER FUNCTIONS
' ============================================================

FUNCTION SnapToGrid(V AS INTEGER) AS INTEGER
    SnapToGrid = INT((V + 4) / 8) * 8
END FUNCTION

FUNCTION DefaultWidth(CompType AS STRING) AS INTEGER
    DIM CT AS STRING
    CT = UCASE$(CompType)
    IF CT = "PBUTTON" THEN DefaultWidth = 80 : EXIT FUNCTION
    IF CT = "PLABEL" THEN DefaultWidth = 100 : EXIT FUNCTION
    IF CT = "PEDIT" THEN DefaultWidth = 120 : EXIT FUNCTION
    IF CT = "PCHECKBOX" THEN DefaultWidth = 100 : EXIT FUNCTION
    IF CT = "PCOMBOBOX" THEN DefaultWidth = 120 : EXIT FUNCTION
    IF CT = "PPANEL" THEN DefaultWidth = 200 : EXIT FUNCTION
    IF CT = "PRADIOBUTTON" THEN DefaultWidth = 100 : EXIT FUNCTION
    IF CT = "PLISTBOX" THEN DefaultWidth = 120 : EXIT FUNCTION
    IF CT = "PGROUPBOX" THEN DefaultWidth = 200 : EXIT FUNCTION
    IF CT = "PPROGRESSBAR" THEN DefaultWidth = 150 : EXIT FUNCTION
    IF CT = "PTIMER" THEN DefaultWidth = 32 : EXIT FUNCTION
    IF CT = "PRICHEDIT" THEN DefaultWidth = 200 : EXIT FUNCTION
    IF CT = "PCANVAS" THEN DefaultWidth = 200 : EXIT FUNCTION
    IF CT = "PMYSQL" THEN DefaultWidth = 48 : EXIT FUNCTION
    IF CT = "PSQLITE" THEN DefaultWidth = 48 : EXIT FUNCTION
    IF CT = "PTREEVIEW" THEN DefaultWidth = 150 : EXIT FUNCTION
    IF CT = "PIMAGE" THEN DefaultWidth = 100 : EXIT FUNCTION
    IF CT = "PTRACKBAR" THEN DefaultWidth = 150 : EXIT FUNCTION
    IF CT = "PSPLITTER" THEN DefaultWidth = 300 : EXIT FUNCTION
    IF CT = "PSTRINGGRID" THEN DefaultWidth = 200 : EXIT FUNCTION
    IF CT = "PSCROLLBOX" THEN DefaultWidth = 200 : EXIT FUNCTION
    DefaultWidth = 100
END FUNCTION

FUNCTION DefaultHeight(CompType AS STRING) AS INTEGER
    DIM CT AS STRING
    CT = UCASE$(CompType)
    IF CT = "PBUTTON" THEN DefaultHeight = 30 : EXIT FUNCTION
    IF CT = "PLABEL" THEN DefaultHeight = 20 : EXIT FUNCTION
    IF CT = "PEDIT" THEN DefaultHeight = 24 : EXIT FUNCTION
    IF CT = "PCHECKBOX" THEN DefaultHeight = 24 : EXIT FUNCTION
    IF CT = "PCOMBOBOX" THEN DefaultHeight = 24 : EXIT FUNCTION
    IF CT = "PPANEL" THEN DefaultHeight = 150 : EXIT FUNCTION
    IF CT = "PRADIOBUTTON" THEN DefaultHeight = 24 : EXIT FUNCTION
    IF CT = "PLISTBOX" THEN DefaultHeight = 100 : EXIT FUNCTION
    IF CT = "PGROUPBOX" THEN DefaultHeight = 150 : EXIT FUNCTION
    IF CT = "PPROGRESSBAR" THEN DefaultHeight = 20 : EXIT FUNCTION
    IF CT = "PTIMER" THEN DefaultHeight = 32 : EXIT FUNCTION
    IF CT = "PRICHEDIT" THEN DefaultHeight = 120 : EXIT FUNCTION
    IF CT = "PCANVAS" THEN DefaultHeight = 150 : EXIT FUNCTION
    IF CT = "PMYSQL" THEN DefaultHeight = 48 : EXIT FUNCTION
    IF CT = "PSQLITE" THEN DefaultHeight = 48 : EXIT FUNCTION
    IF CT = "PTREEVIEW" THEN DefaultHeight = 150 : EXIT FUNCTION
    IF CT = "PIMAGE" THEN DefaultHeight = 100 : EXIT FUNCTION
    IF CT = "PTRACKBAR" THEN DefaultHeight = 25 : EXIT FUNCTION
    IF CT = "PSPLITTER" THEN DefaultHeight = 200 : EXIT FUNCTION
    IF CT = "PSTRINGGRID" THEN DefaultHeight = 120 : EXIT FUNCTION
    IF CT = "PSCROLLBOX" THEN DefaultHeight = 150 : EXIT FUNCTION
    DefaultHeight = 30
END FUNCTION

FUNCTION GenerateCompName(CompType AS STRING) AS STRING
    DIM CT AS STRING
    CT = UCASE$(CompType)
    IF CT = "PBUTTON" THEN BtnCount = BtnCount + 1 : GenerateCompName = "Button" + STR$(BtnCount) : EXIT FUNCTION
    IF CT = "PLABEL" THEN LblCount = LblCount + 1 : GenerateCompName = "Label" + STR$(LblCount) : EXIT FUNCTION
    IF CT = "PEDIT" THEN EdtCount = EdtCount + 1 : GenerateCompName = "Edit" + STR$(EdtCount) : EXIT FUNCTION
    IF CT = "PCHECKBOX" THEN ChkCount = ChkCount + 1 : GenerateCompName = "CheckBox" + STR$(ChkCount) : EXIT FUNCTION
    IF CT = "PCOMBOBOX" THEN CmbCount = CmbCount + 1 : GenerateCompName = "ComboBox" + STR$(CmbCount) : EXIT FUNCTION
    IF CT = "PPANEL" THEN PnlCount = PnlCount + 1 : GenerateCompName = "Panel" + STR$(PnlCount) : EXIT FUNCTION
    IF CT = "PRADIOBUTTON" THEN RadCount = RadCount + 1 : GenerateCompName = "Radio" + STR$(RadCount) : EXIT FUNCTION
    IF CT = "PLISTBOX" THEN LstCount = LstCount + 1 : GenerateCompName = "ListBox" + STR$(LstCount) : EXIT FUNCTION
    IF CT = "PGROUPBOX" THEN GrpCount = GrpCount + 1 : GenerateCompName = "GroupBox" + STR$(GrpCount) : EXIT FUNCTION
    IF CT = "PPROGRESSBAR" THEN PrgCount = PrgCount + 1 : GenerateCompName = "ProgressBar" + STR$(PrgCount) : EXIT FUNCTION
    IF CT = "PTIMER" THEN TmrCount = TmrCount + 1 : GenerateCompName = "Timer" + STR$(TmrCount) : EXIT FUNCTION
    IF CT = "PRICHEDIT" THEN RchCount = RchCount + 1 : GenerateCompName = "RichEdit" + STR$(RchCount) : EXIT FUNCTION
    IF CT = "PCANVAS" THEN CnvCount = CnvCount + 1 : GenerateCompName = "Canvas" + STR$(CnvCount) : EXIT FUNCTION
    IF CT = "PMYSQL" THEN MySqlCount = MySqlCount + 1 : GenerateCompName = "MySQL" + STR$(MySqlCount) : EXIT FUNCTION
    IF CT = "PSQLITE" THEN SQLiteCount = SQLiteCount + 1 : GenerateCompName = "SQLite" + STR$(SQLiteCount) : EXIT FUNCTION
    IF CT = "PTREEVIEW" THEN TrvCount = TrvCount + 1 : GenerateCompName = "TreeView" + STR$(TrvCount) : EXIT FUNCTION
    IF CT = "PIMAGE" THEN ImgCount = ImgCount + 1 : GenerateCompName = "Image" + STR$(ImgCount) : EXIT FUNCTION
    IF CT = "PTRACKBAR" THEN TrkCount = TrkCount + 1 : GenerateCompName = "TrackBar" + STR$(TrkCount) : EXIT FUNCTION
    IF CT = "PSPLITTER" THEN SplCount = SplCount + 1 : GenerateCompName = "Splitter" + STR$(SplCount) : EXIT FUNCTION
    IF CT = "PSTRINGGRID" THEN SgdCount = SgdCount + 1 : GenerateCompName = "StringGrid" + STR$(SgdCount) : EXIT FUNCTION
    IF CT = "PSCROLLBOX" THEN SbxCount = SbxCount + 1 : GenerateCompName = "ScrollBox" + STR$(SbxCount) : EXIT FUNCTION
    GenerateCompName = "Component1"
END FUNCTION

FUNCTION GetEventParams(EvtName AS STRING) AS STRING
    DIM UE AS STRING
    UE = UCASE$(EvtName)
    IF UE = "ONMOUSEDOWN" OR UE = "ONMOUSEUP" THEN
        GetEventParams = "(Button AS INTEGER, X AS INTEGER, Y AS INTEGER, Shift AS INTEGER)"
        EXIT FUNCTION
    END IF
    IF UE = "ONMOUSEMOVE" THEN
        GetEventParams = "(X AS INTEGER, Y AS INTEGER, Shift AS INTEGER)"
        EXIT FUNCTION
    END IF
    IF UE = "ONKEYDOWN" OR UE = "ONKEYUP" THEN
        GetEventParams = "(Key AS WORD, Shift AS INTEGER)"
        EXIT FUNCTION
    END IF
    IF UE = "ONKEYPRESS" THEN
        GetEventParams = "(Key AS BYTE)"
        EXIT FUNCTION
    END IF
    IF UE = "ONCLOSE" THEN
        GetEventParams = "(Action AS INTEGER)"
        EXIT FUNCTION
    END IF
    IF UE = "ONERROR" THEN
        GetEventParams = "(ErrMsg AS STRING)"
        EXIT FUNCTION
    END IF
    GetEventParams = ""
END FUNCTION

FUNCTION GetDefaultEvent(CompType AS STRING) AS STRING
    DIM CT AS STRING
    CT = UCASE$(CompType)
    IF CT = "PBUTTON" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PLABEL" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PEDIT" THEN GetDefaultEvent = "OnChange" : EXIT FUNCTION
    IF CT = "PCHECKBOX" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PCOMBOBOX" THEN GetDefaultEvent = "OnChange" : EXIT FUNCTION
    IF CT = "PPANEL" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PRADIOBUTTON" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PLISTBOX" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PGROUPBOX" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PTIMER" THEN GetDefaultEvent = "OnTimer" : EXIT FUNCTION
    IF CT = "PRICHEDIT" THEN GetDefaultEvent = "OnChange" : EXIT FUNCTION
    IF CT = "PCANVAS" THEN GetDefaultEvent = "OnPaint" : EXIT FUNCTION
    IF CT = "PPROGRESSBAR" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PTREEVIEW" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PIMAGE" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PTRACKBAR" THEN GetDefaultEvent = "OnChange" : EXIT FUNCTION
    IF CT = "PMYSQL" THEN GetDefaultEvent = "OnConnect" : EXIT FUNCTION
    IF CT = "PSQLITE" THEN GetDefaultEvent = "OnConnect" : EXIT FUNCTION
    IF CT = "PSTRINGGRID" THEN GetDefaultEvent = "OnChange" : EXIT FUNCTION
    IF CT = "PSPLITTER" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    IF CT = "PSCROLLBOX" THEN GetDefaultEvent = "OnClick" : EXIT FUNCTION
    GetDefaultEvent = ""
END FUNCTION

FUNCTION ExtractSub(Source AS STRING, SubName AS STRING) AS STRING
    DIM NL AS STRING
    DIM SLine AS STRING
    DIM Remaining AS STRING
    DIM Pos AS INTEGER
    DIM InSub AS INTEGER
    DIM Body AS STRING
    DIM UCLine AS STRING

    NL = CHR$(10)
    ExtractSub = ""
    Remaining = Source
    InSub = 0
    Body = ""

    DO WHILE LEN(Remaining) > 0
        Pos = INSTR(Remaining, NL)
        IF Pos > 0 THEN
            SLine = LEFT$(Remaining, Pos - 1)
            Remaining = MID$(Remaining, Pos + 1)
        ELSE
            SLine = Remaining
            Remaining = ""
        END IF
        UCLine = UCASE$(LTRIM$(SLine))
        IF InSub = 0 THEN
            IF LEFT$(UCLine, 4) = "SUB " AND INSTR(UCASE$(SLine), UCASE$(SubName)) > 0 THEN
                InSub = 1
                Body = SLine + NL
            END IF
        ELSE
            Body = Body + SLine + NL
            IF UCLine = "END SUB" THEN
                ExtractSub = Body
                EXIT FUNCTION
            END IF
        END IF
    LOOP
END FUNCTION

FUNCTION GenerateSubCode(ExistingCode AS STRING, HandlerName AS STRING, CompName AS STRING, EvtName AS STRING) AS STRING
    DIM NL AS STRING
    DIM Existing AS STRING
    DIM Params AS STRING
    NL = CHR$(10)
    Existing = ExtractSub(ExistingCode, HandlerName)
    IF Existing <> "" THEN
        GenerateSubCode = Existing + NL
    ELSE
        Params = GetEventParams(EvtName)
        GenerateSubCode = "SUB " + HandlerName + Params + NL + "    ' TODO: Handle " + CompName + " " + EvtName + NL + "END SUB" + NL + NL
    END IF
END FUNCTION

' ============================================================
' UPDATE OBJECT COMBO
' ============================================================
SUB UpdateObjCombo
    DIM I AS INTEGER
    ObjCombo.Clear
    ObjCombo.AddItems("Form1")
    FOR I = 0 TO DesignSurface.CompCount - 1
        ObjCombo.AddItems(DesignSurface.GetName(I))
    NEXT I
    IF SelIndex = 0 THEN
        ObjCombo.ItemIndex = 0
    ELSEIF SelIndex > 0 AND SelIndex <= DesignSurface.CompCount THEN
        ObjCombo.ItemIndex = SelIndex
    END IF
END SUB

' ============================================================
' UPDATE EVENT SUGGESTIONS
' ============================================================
SUB UpdateEventSuggestions
    DIM SubNames AS STRING
    SubNames = CodeEditor.GetSubList
    EvtGrid.SetSuggestions(SubNames)
END SUB

' ============================================================
' SAVE EVENTS
' ============================================================
SUB SaveEvents
    DIM I AS INTEGER
    DIM R AS INTEGER

    IF SelIndex = 0 THEN
        FOR R = 0 TO EvtGrid.Rows - 1
            DIM FEvt AS STRING
            FEvt = UCASE$(EvtGrid.Cell(R, 0))
            IF FEvt = "ONSHOW" THEN FormOnShow = EvtGrid.Cell(R, 1)
            IF FEvt = "ONCLOSE" THEN FormOnClose = EvtGrid.Cell(R, 1)
            IF FEvt = "ONRESIZE" THEN FormOnResize = EvtGrid.Cell(R, 1)
            IF FEvt = "ONKEYDOWN" THEN FormOnKeyDown = EvtGrid.Cell(R, 1)
            IF FEvt = "ONKEYPRESS" THEN FormOnKeyPress = EvtGrid.Cell(R, 1)
            IF FEvt = "ONKEYUP" THEN FormOnKeyUp = EvtGrid.Cell(R, 1)
            IF FEvt = "ONCLICK" THEN FormOnClick = EvtGrid.Cell(R, 1)
            IF FEvt = "ONMOUSEDOWN" THEN FormOnMouseDown = EvtGrid.Cell(R, 1)
            IF FEvt = "ONMOUSEMOVE" THEN FormOnMouseMove = EvtGrid.Cell(R, 1)
            IF FEvt = "ONMOUSEUP" THEN FormOnMouseUp = EvtGrid.Cell(R, 1)
            IF FEvt = "ONPAINT" THEN FormOnPaint = EvtGrid.Cell(R, 1)
        NEXT R
    ELSEIF SelIndex >= 1 AND SelIndex <= DesignSurface.CompCount THEN
        I = SelIndex
        FOR R = 0 TO EvtGrid.Rows - 1
            DIM EName AS STRING
            EName = UCASE$(EvtGrid.Cell(R, 0))
            IF EName = "ONCLICK" THEN EvtOnClick(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONDBLCLICK" THEN EvtOnDblClick(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONCHANGE" THEN EvtOnChange(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONMOUSEDOWN" THEN EvtOnMouseDown(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONMOUSEMOVE" THEN EvtOnMouseMove(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONMOUSEUP" THEN EvtOnMouseUp(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONKEYDOWN" THEN EvtOnKeyDown(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONKEYPRESS" THEN EvtOnKeyPress(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONKEYUP" THEN EvtOnKeyUp(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONTIMER" THEN EvtOnTimer(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONPAINT" THEN EvtOnPaint(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONENTER" THEN EvtOnEnter(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONCONNECT" THEN EvtOnConnect(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONDISCONNECT" THEN EvtOnDisconnect(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONERROR" THEN EvtOnError(I) = EvtGrid.Cell(R, 1)
            IF EName = "ONQUERYDONE" THEN EvtOnQueryDone(I) = EvtGrid.Cell(R, 1)
        NEXT R
    END IF
END SUB

' ============================================================
' FILL PROPERTIES
' ============================================================
SUB FillProperties
    DIM R AS INTEGER
    DIM CT AS STRING
    DIM CI AS INTEGER

    SyncGuard = 1
    PropGrid.Clear

    IF SelIndex = 0 THEN
        PropGrid.AddRow("(Name)", "Form1")
        PropGrid.AddRow("Caption", "Form1")
        PropGrid.AddRow("Width", STR$(DESIGN_W))
        PropGrid.AddRow("Height", STR$(DESIGN_H))
        PropGrid.AddRow("BorderStyle", "2")
        PropGrid.AddRow("Color", "")
        PropGrid.AddRow("Font.Name", "Helvetica")
        PropGrid.AddRow("Font.Size", "9")
        PropGrid.AddRow("Font.Bold", "False")
        PropGrid.AddRow("KeyPreview", "False")
        SyncGuard = 0
        EXIT SUB
    END IF

    CI = SelIndex - 1
    CT = UCASE$(DesignSurface.GetType(CI))

    PropGrid.AddRow("(Name)", DesignSurface.GetName(CI))
    PropGrid.AddRow("Left", STR$(DesignSurface.GetCompX(CI)))
    PropGrid.AddRow("Top", STR$(DesignSurface.GetCompY(CI)))
    PropGrid.AddRow("Width", STR$(DesignSurface.GetCompW(CI)))
    PropGrid.AddRow("Height", STR$(DesignSurface.GetCompH(CI)))

    IF CT = "PBUTTON" OR CT = "PLABEL" OR CT = "PCHECKBOX" OR CT = "PRADIOBUTTON" OR CT = "PGROUPBOX" OR CT = "PPANEL" THEN
        PropGrid.AddRow("Caption", DesignSurface.GetProp(CI, "caption"))
    END IF
    IF CT = "PEDIT" OR CT = "PRICHEDIT" THEN
        PropGrid.AddRow("Text", DesignSurface.GetProp(CI, "text"))
    END IF

    IF CT = "PLABEL" THEN
        DIM AlVal AS STRING
        AlVal = DesignSurface.GetProp(CI, "alignment")
        IF AlVal = "" THEN AlVal = "0"
        PropGrid.AddRow("Alignment", AlVal)
        PropGrid.AddRow("WordWrap", DesignSurface.GetProp(CI, "wordwrap"))
    END IF

    IF CT = "PCHECKBOX" OR CT = "PRADIOBUTTON" THEN
        DIM ChkVal AS STRING
        ChkVal = DesignSurface.GetProp(CI, "checked")
        IF ChkVal = "" THEN ChkVal = "False"
        PropGrid.AddRow("Checked", ChkVal)
    END IF

    IF CT <> "PTIMER" AND CT <> "PMYSQL" AND CT <> "PSQLITE" THEN
        DIM CVal AS STRING
        CVal = DesignSurface.GetProp(CI, "color")
        PropGrid.AddRow("Color", CVal)
    END IF

    IF CT = "PPANEL" OR CT = "PEDIT" OR CT = "PLISTBOX" OR CT = "PRICHEDIT" THEN
        DIM BSVal AS STRING
        BSVal = DesignSurface.GetProp(CI, "borderstyle")
        IF BSVal = "" THEN BSVal = "1"
        PropGrid.AddRow("BorderStyle", BSVal)
    END IF

    IF CT = "PPANEL" THEN
        DIM BIVal AS STRING
        DIM BOVal AS STRING
        BIVal = DesignSurface.GetProp(CI, "bevelinner")
        BOVal = DesignSurface.GetProp(CI, "bevelouter")
        IF BIVal = "" THEN BIVal = "0"
        IF BOVal = "" THEN BOVal = "2"
        PropGrid.AddRow("BevelInner", BIVal)
        PropGrid.AddRow("BevelOuter", BOVal)
    END IF

    IF CT <> "PTIMER" AND CT <> "PMYSQL" AND CT <> "PSQLITE" AND CT <> "PPROGRESSBAR" THEN
        PropGrid.AddRow("Font.Name", DesignSurface.GetProp(CI, "font.name"))
        PropGrid.AddRow("Font.Size", DesignSurface.GetProp(CI, "font.size"))
        PropGrid.AddRow("Font.Bold", DesignSurface.GetProp(CI, "font.bold"))
        PropGrid.AddRow("FontColor", DesignSurface.GetProp(CI, "fontcolor"))
    END IF

    IF CT = "PEDIT" THEN
        DIM RDVal AS STRING
        RDVal = DesignSurface.GetProp(CI, "readonly")
        IF RDVal = "" THEN RDVal = "False"
        PropGrid.AddRow("ReadOnly", RDVal)
        PropGrid.AddRow("MaxLength", DesignSurface.GetProp(CI, "maxlength"))
        PropGrid.AddRow("PasswordChar", DesignSurface.GetProp(CI, "passwordchar"))
    END IF

    IF CT = "PRICHEDIT" THEN
        DIM RORch AS STRING
        RORch = DesignSurface.GetProp(CI, "readonly")
        IF RORch = "" THEN RORch = "False"
        PropGrid.AddRow("ReadOnly", RORch)
        DIM WWVal AS STRING
        WWVal = DesignSurface.GetProp(CI, "wordwrap")
        IF WWVal = "" THEN WWVal = "True"
        PropGrid.AddRow("WordWrap", WWVal)
        PropGrid.AddRow("ScrollBars", DesignSurface.GetProp(CI, "scrollbars"))
    END IF

    IF CT = "PLISTBOX" THEN
        DIM MSVal AS STRING
        MSVal = DesignSurface.GetProp(CI, "multiselect")
        IF MSVal = "" THEN MSVal = "False"
        PropGrid.AddRow("MultiSelect", MSVal)
        DIM SortVal AS STRING
        SortVal = DesignSurface.GetProp(CI, "sorted")
        IF SortVal = "" THEN SortVal = "False"
        PropGrid.AddRow("Sorted", SortVal)
    END IF

    IF CT = "PCOMBOBOX" THEN
        PropGrid.AddRow("Sorted", DesignSurface.GetProp(CI, "sorted"))
    END IF

    IF CT <> "PTIMER" AND CT <> "PMYSQL" AND CT <> "PSQLITE" THEN
        PropGrid.AddRow("Enabled", "True")
        PropGrid.AddRow("Visible", "True")
    END IF

    IF CT = "PTIMER" THEN
        PropGrid.AddRow("Interval", DesignSurface.GetProp(CI, "interval"))
        PropGrid.AddRow("Enabled", "True")
    END IF

    IF CT = "PMYSQL" THEN
        PropGrid.AddRow("Host", DesignSurface.GetProp(CI, "host"))
        PropGrid.AddRow("User", DesignSurface.GetProp(CI, "user"))
        PropGrid.AddRow("Password", DesignSurface.GetProp(CI, "password"))
        PropGrid.AddRow("Port", DesignSurface.GetProp(CI, "port"))
    END IF

    IF CT = "PSQLITE" THEN
        PropGrid.AddRow("DB", DesignSurface.GetProp(CI, "db"))
    END IF

    IF CT = "PTRACKBAR" THEN
        DIM TBMin AS STRING
        DIM TBMax AS STRING
        DIM TBPos AS STRING
        TBMin = DesignSurface.GetProp(CI, "min")
        TBMax = DesignSurface.GetProp(CI, "max")
        TBPos = DesignSurface.GetProp(CI, "position")
        IF TBMin = "" THEN TBMin = "0"
        IF TBMax = "" THEN TBMax = "100"
        IF TBPos = "" THEN TBPos = "0"
        PropGrid.AddRow("Min", TBMin)
        PropGrid.AddRow("Max", TBMax)
        PropGrid.AddRow("Position", TBPos)
    END IF

    IF CT = "PIMAGE" THEN
        PropGrid.AddRow("Stretch", DesignSurface.GetProp(CI, "stretch"))
    END IF

    IF CT = "PSPLITTER" THEN
        DIM SOr AS STRING
        SOr = DesignSurface.GetProp(CI, "orientation")
        IF SOr = "" THEN SOr = "0"
        PropGrid.AddRow("Orientation", SOr)
    END IF

    SyncGuard = 0
END SUB

' ============================================================
' FILL EVENTS
' ============================================================
SUB FillEvents
    DIM CT AS STRING
    DIM CI AS INTEGER

    SyncGuard = 1
    EvtGrid.Clear
    UpdateEventSuggestions

    IF SelIndex = 0 THEN
        EvtGrid.AddRow("OnShow", FormOnShow)
        EvtGrid.AddRow("OnClose", FormOnClose)
        EvtGrid.AddRow("OnResize", FormOnResize)
        EvtGrid.AddRow("OnClick", FormOnClick)
        EvtGrid.AddRow("OnKeyDown", FormOnKeyDown)
        EvtGrid.AddRow("OnKeyPress", FormOnKeyPress)
        EvtGrid.AddRow("OnKeyUp", FormOnKeyUp)
        EvtGrid.AddRow("OnMouseDown", FormOnMouseDown)
        EvtGrid.AddRow("OnMouseMove", FormOnMouseMove)
        EvtGrid.AddRow("OnMouseUp", FormOnMouseUp)
        EvtGrid.AddRow("OnPaint", FormOnPaint)
        SyncGuard = 0
        EXIT SUB
    END IF

    CI = SelIndex - 1
    CT = UCASE$(DesignSurface.GetType(CI))

    IF CT = "PBUTTON" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseMove", EvtOnMouseMove(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
        EvtGrid.AddRow("OnKeyDown", EvtOnKeyDown(SelIndex))
        EvtGrid.AddRow("OnKeyPress", EvtOnKeyPress(SelIndex))
        EvtGrid.AddRow("OnKeyUp", EvtOnKeyUp(SelIndex))
    END IF
    IF CT = "PLABEL" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseMove", EvtOnMouseMove(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
    END IF
    IF CT = "PEDIT" THEN
        EvtGrid.AddRow("OnChange", EvtOnChange(SelIndex))
        EvtGrid.AddRow("OnKeyDown", EvtOnKeyDown(SelIndex))
        EvtGrid.AddRow("OnKeyPress", EvtOnKeyPress(SelIndex))
        EvtGrid.AddRow("OnKeyUp", EvtOnKeyUp(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
    END IF
    IF CT = "PCHECKBOX" OR CT = "PRADIOBUTTON" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
    END IF
    IF CT = "PCOMBOBOX" THEN
        EvtGrid.AddRow("OnChange", EvtOnChange(SelIndex))
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
    END IF
    IF CT = "PPANEL" OR CT = "PGROUPBOX" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseMove", EvtOnMouseMove(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
    END IF
    IF CT = "PLISTBOX" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
        EvtGrid.AddRow("OnKeyDown", EvtOnKeyDown(SelIndex))
        EvtGrid.AddRow("OnKeyPress", EvtOnKeyPress(SelIndex))
    END IF
    IF CT = "PTIMER" THEN
        EvtGrid.AddRow("OnTimer", EvtOnTimer(SelIndex))
    END IF
    IF CT = "PRICHEDIT" THEN
        EvtGrid.AddRow("OnChange", EvtOnChange(SelIndex))
        EvtGrid.AddRow("OnKeyDown", EvtOnKeyDown(SelIndex))
        EvtGrid.AddRow("OnKeyPress", EvtOnKeyPress(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseMove", EvtOnMouseMove(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
    END IF
    IF CT = "PCANVAS" THEN
        EvtGrid.AddRow("OnPaint", EvtOnPaint(SelIndex))
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseMove", EvtOnMouseMove(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
    END IF
    IF CT = "PPROGRESSBAR" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
    END IF
    IF CT = "PTREEVIEW" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
        EvtGrid.AddRow("OnChange", EvtOnChange(SelIndex))
    END IF
    IF CT = "PIMAGE" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
        EvtGrid.AddRow("OnMouseDown", EvtOnMouseDown(SelIndex))
        EvtGrid.AddRow("OnMouseMove", EvtOnMouseMove(SelIndex))
        EvtGrid.AddRow("OnMouseUp", EvtOnMouseUp(SelIndex))
    END IF
    IF CT = "PTRACKBAR" THEN
        EvtGrid.AddRow("OnChange", EvtOnChange(SelIndex))
    END IF
    IF CT = "PSTRINGGRID" THEN
        EvtGrid.AddRow("OnChange", EvtOnChange(SelIndex))
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
        EvtGrid.AddRow("OnDblClick", EvtOnDblClick(SelIndex))
    END IF
    IF CT = "PSPLITTER" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
    END IF
    IF CT = "PSCROLLBOX" THEN
        EvtGrid.AddRow("OnClick", EvtOnClick(SelIndex))
    END IF
    IF CT = "PMYSQL" OR CT = "PSQLITE" THEN
        EvtGrid.AddRow("OnConnect", EvtOnConnect(SelIndex))
        EvtGrid.AddRow("OnDisconnect", EvtOnDisconnect(SelIndex))
        EvtGrid.AddRow("OnError", EvtOnError(SelIndex))
        EvtGrid.AddRow("OnQueryDone", EvtOnQueryDone(SelIndex))
    END IF

    SyncGuard = 0
END SUB

