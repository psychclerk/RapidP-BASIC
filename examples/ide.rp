' ============================================================
' DESIGN SURFACE CALLBACKS
' ============================================================

SUB DesignSelect(Index AS INTEGER)
    IF Index < 0 THEN
        SelIndex = 0
    ELSE
        SelIndex = Index + 1
    END IF
    FillProperties
    FillEvents
    UpdateObjCombo
    IF SelIndex = 0 THEN
        StatusBar.Caption = "Form1 selected"
    ELSE
        StatusBar.Caption = DesignSurface.GetName(Index) + " selected"
    END IF
END SUB

SUB DesignMove(Index AS INTEGER, X AS INTEGER, Y AS INTEGER, W AS INTEGER, H AS INTEGER)
    IF SelIndex = Index + 1 THEN
        SyncGuard = 1
        FillProperties
        SyncGuard = 0
    END IF
END SUB

SUB DesignDblClick(Index AS INTEGER)
    DIM CT AS STRING
    DIM CName AS STRING
    DIM DefEvt AS STRING
    DIM HandlerName AS STRING
    DIM SI AS INTEGER

    SI = Index + 1
    CT = DesignSurface.GetType(Index)
    CName = DesignSurface.GetName(Index)
    DefEvt = GetDefaultEvent(CT)
    IF DefEvt = "" THEN EXIT SUB

    HandlerName = CName + "_" + DefEvt

    DIM UEvt AS STRING
    UEvt = UCASE$(DefEvt)
    IF UEvt = "ONCLICK" THEN
        IF EvtOnClick(SI) <> "" THEN
            HandlerName = EvtOnClick(SI)
        ELSE
            EvtOnClick(SI) = HandlerName
        END IF
    END IF
    IF UEvt = "ONCHANGE" THEN
        IF EvtOnChange(SI) <> "" THEN
            HandlerName = EvtOnChange(SI)
        ELSE
            EvtOnChange(SI) = HandlerName
        END IF
    END IF
    IF UEvt = "ONTIMER" THEN
        IF EvtOnTimer(SI) <> "" THEN
            HandlerName = EvtOnTimer(SI)
        ELSE
            EvtOnTimer(SI) = HandlerName
        END IF
    END IF
    IF UEvt = "ONPAINT" THEN
        IF EvtOnPaint(SI) <> "" THEN
            HandlerName = EvtOnPaint(SI)
        ELSE
            EvtOnPaint(SI) = HandlerName
        END IF
    END IF
    IF UEvt = "ONCONNECT" THEN
        IF EvtOnConnect(SI) <> "" THEN
            HandlerName = EvtOnConnect(SI)
        ELSE
            EvtOnConnect(SI) = HandlerName
        END IF
    END IF

    GenerateCode

    DesignSurface.Hide
    CodeEditor.Visible = 1
    ShowingCode = 1
    FillEvents

    CodeEditor.GotoSub(HandlerName)
    StatusBar.Caption = "Editing: " + HandlerName
END SUB

SUB DesignBgClick(X AS INTEGER, Y AS INTEGER)
    IF CurrentTool <> "" THEN
        DIM CName AS STRING
        DIM SX AS INTEGER
        DIM SY AS INTEGER
        DIM DW AS INTEGER
        DIM DH AS INTEGER
        SX = SnapToGrid(X)
        SY = SnapToGrid(Y)
        DW = DefaultWidth(CurrentTool)
        DH = DefaultHeight(CurrentTool)
        CName = GenerateCompName(CurrentTool)
        DesignSurface.AddComponent(CurrentTool, CName, SX, SY, DW, DH)
        SelIndex = DesignSurface.CompCount
        DesignSurface.SelectComp(SelIndex - 1)
        DIM CI AS INTEGER
        CI = SelIndex - 1
        DesignSurface.SetProp(CI, "caption", CName)
        IF UCASE$(CurrentTool) = "PTIMER" THEN
            DesignSurface.SetProp(CI, "interval", "1000")
        END IF
        IF UCASE$(CurrentTool) = "PMYSQL" THEN
            DesignSurface.SetProp(CI, "host", "localhost")
            DesignSurface.SetProp(CI, "user", "root")
            DesignSurface.SetProp(CI, "password", "")
            DesignSurface.SetProp(CI, "port", "3306")
        END IF
        IF UCASE$(CurrentTool) = "PSQLITE" THEN
            DesignSurface.SetProp(CI, "db", "my_data.db")
        END IF
        IF UCASE$(CurrentTool) = "PTRACKBAR" THEN
            DesignSurface.SetProp(CI, "min", "0")
            DesignSurface.SetProp(CI, "max", "100")
            DesignSurface.SetProp(CI, "position", "0")
        END IF
        CurrentTool = ""
        FillProperties
        FillEvents
        UpdateObjCombo
        StatusBar.Caption = CName + " placed"
    ELSE
        SelIndex = 0
        FillProperties
        FillEvents
        UpdateObjCombo
        StatusBar.Caption = "Form1 selected"
    END IF
END SUB

SUB PropGridChange
    IF SyncGuard = 1 THEN EXIT SUB
    DIM PropName AS STRING
    DIM PropVal AS STRING
    DIM I AS INTEGER
    DIM CI AS INTEGER
    SyncGuard = 1

    IF SelIndex = 0 THEN
        FOR I = 0 TO PropGrid.Rows - 1
            PropName = UCASE$(PropGrid.Cell(I, 0))
            PropVal = PropGrid.Cell(I, 1)
            IF PropName = "CAPTION" THEN DesignSurface.FormCaption = PropVal
            IF PropName = "WIDTH" THEN DesignSurface.Width = VAL(PropVal)
            IF PropName = "HEIGHT" THEN DesignSurface.Height = VAL(PropVal)
        NEXT I
        SyncGuard = 0
        EXIT SUB
    END IF

    CI = SelIndex - 1
    FOR I = 0 TO PropGrid.Rows - 1
        PropName = UCASE$(PropGrid.Cell(I, 0))
        PropVal = PropGrid.Cell(I, 1)
        IF PropName = "(NAME)" AND PropVal <> "" THEN
            DesignSurface.SetName(CI, PropVal)
            UpdateObjCombo
        END IF
        IF PropName = "LEFT" THEN DesignSurface.SetCompBounds(CI, VAL(PropVal), DesignSurface.GetCompY(CI), DesignSurface.GetCompW(CI), DesignSurface.GetCompH(CI))
        IF PropName = "TOP" THEN DesignSurface.SetCompBounds(CI, DesignSurface.GetCompX(CI), VAL(PropVal), DesignSurface.GetCompW(CI), DesignSurface.GetCompH(CI))
        IF PropName = "WIDTH" THEN DesignSurface.SetCompBounds(CI, DesignSurface.GetCompX(CI), DesignSurface.GetCompY(CI), VAL(PropVal), DesignSurface.GetCompH(CI))
        IF PropName = "HEIGHT" THEN DesignSurface.SetCompBounds(CI, DesignSurface.GetCompX(CI), DesignSurface.GetCompY(CI), DesignSurface.GetCompW(CI), VAL(PropVal))
        IF PropName = "CAPTION" THEN DesignSurface.SetProp(CI, "caption", PropVal)
        IF PropName = "TEXT" THEN DesignSurface.SetProp(CI, "text", PropVal)
        IF PropName = "COLOR" THEN DesignSurface.SetProp(CI, "color", PropVal)
        IF PropName = "FONTCOLOR" THEN DesignSurface.SetProp(CI, "fontcolor", PropVal)
        IF PropName = "FONT.NAME" THEN DesignSurface.SetProp(CI, "font.name", PropVal)
        IF PropName = "FONT.SIZE" THEN DesignSurface.SetProp(CI, "font.size", PropVal)
        IF PropName = "FONT.BOLD" THEN DesignSurface.SetProp(CI, "font.bold", PropVal)
        IF PropName = "BORDERSTYLE" THEN DesignSurface.SetProp(CI, "borderstyle", PropVal)
        IF PropName = "BEVELINNER" THEN DesignSurface.SetProp(CI, "bevelinner", PropVal)
        IF PropName = "BEVELOUTER" THEN DesignSurface.SetProp(CI, "bevelouter", PropVal)
        IF PropName = "ALIGNMENT" THEN DesignSurface.SetProp(CI, "alignment", PropVal)
        IF PropName = "READONLY" THEN DesignSurface.SetProp(CI, "readonly", PropVal)
        IF PropName = "CHECKED" THEN DesignSurface.SetProp(CI, "checked", PropVal)
        IF PropName = "WORDWRAP" THEN DesignSurface.SetProp(CI, "wordwrap", PropVal)
        IF PropName = "ENABLED" THEN DesignSurface.SetProp(CI, "enabled", PropVal)
        IF PropName = "VISIBLE" THEN DesignSurface.SetProp(CI, "visible", PropVal)
        IF PropName = "INTERVAL" THEN DesignSurface.SetProp(CI, "interval", PropVal)
        IF PropName = "HOST" THEN DesignSurface.SetProp(CI, "host", PropVal)
        IF PropName = "USER" THEN DesignSurface.SetProp(CI, "user", PropVal)
        IF PropName = "PASSWORD" THEN DesignSurface.SetProp(CI, "password", PropVal)
        IF PropName = "PORT" THEN DesignSurface.SetProp(CI, "port", PropVal)
        IF PropName = "DB" THEN DesignSurface.SetProp(CI, "db", PropVal)
        IF PropName = "MIN" THEN DesignSurface.SetProp(CI, "min", PropVal)
        IF PropName = "MAX" THEN DesignSurface.SetProp(CI, "max", PropVal)
        IF PropName = "POSITION" THEN DesignSurface.SetProp(CI, "position", PropVal)
        IF PropName = "STRETCH" THEN DesignSurface.SetProp(CI, "stretch", PropVal)
        IF PropName = "ORIENTATION" THEN DesignSurface.SetProp(CI, "orientation", PropVal)
        IF PropName = "MULTISELECT" THEN DesignSurface.SetProp(CI, "multiselect", PropVal)
        IF PropName = "SORTED" THEN DesignSurface.SetProp(CI, "sorted", PropVal)
        IF PropName = "MAXLENGTH" THEN DesignSurface.SetProp(CI, "maxlength", PropVal)
        IF PropName = "PASSWORDCHAR" THEN DesignSurface.SetProp(CI, "passwordchar", PropVal)
        IF PropName = "SCROLLBARS" THEN DesignSurface.SetProp(CI, "scrollbars", PropVal)
    NEXT I
    SyncGuard = 0
END SUB

SUB EvtGridChange
    IF SyncGuard = 1 THEN EXIT SUB
    SaveEvents
END SUB

SUB EvtGridDblClick
    DIM R AS INTEGER
    DIM EvtName AS STRING
    DIM CurVal AS STRING
    DIM CName AS STRING
    DIM HandlerName AS STRING
    DIM SI AS INTEGER

    R = EvtGrid.SelectedRow
    IF R < 0 THEN EXIT SUB
    EvtName = EvtGrid.Cell(R, 0)
    CurVal = EvtGrid.Cell(R, 1)
    IF CurVal <> "" THEN
        GenerateCode
        DesignSurface.Hide
        CodeEditor.Visible = 1
        ShowingCode = 1
        CodeEditor.GotoSub(CurVal)
        StatusBar.Caption = "Editing: " + CurVal
        EXIT SUB
    END IF

    IF SelIndex = 0 THEN
        CName = "Form1"
    ELSE
        SI = SelIndex - 1
        CName = DesignSurface.GetName(SI)
    END IF
    HandlerName = CName + "_" + EvtName
    EvtGrid.SetCell(R, 1, HandlerName)
    SaveEvents
    GenerateCode
    DesignSurface.Hide
    CodeEditor.Visible = 1
    ShowingCode = 1
    FillEvents
    CodeEditor.GotoSub(HandlerName)
    StatusBar.Caption = "Editing: " + HandlerName
END SUB

' ============================================================
' CODE GENERATION
' ============================================================
SUB GenerateCode
    DIM Code AS STRING
    DIM I AS INTEGER
    DIM NL AS STRING
    DIM ExistingCode AS STRING
    DIM CI AS INTEGER
    DIM CT AS STRING
    DIM CName AS STRING
    NL = CHR$(10)

    SaveEvents
    ExistingCode = CodeEditor.Text
    Code = "' Generated by RapidP Visual IDE" + NL + NL

    DIM HdrLines AS STRING
    DIM HdrLine AS STRING
    DIM HdrIdx AS INTEGER
    DIM HdrULine AS STRING
    DIM FoundSub AS INTEGER
    DIM UserHeader AS STRING
    UserHeader = ""
    FoundSub = 0
    HdrLines = ExistingCode
    DO WHILE LEN(HdrLines) > 0 AND FoundSub = 0
        HdrIdx = INSTR(HdrLines, NL)
        IF HdrIdx > 0 THEN
            HdrLine = LEFT$(HdrLines, HdrIdx - 1)
            HdrLines = MID$(HdrLines, HdrIdx + 1)
        ELSE
            HdrLine = HdrLines
            HdrLines = ""
        END IF
        HdrULine = UCASE$(LTRIM$(HdrLine))
        IF LEFT$(HdrULine, 4) = "SUB " OR LEFT$(HdrULine, 9) = "FUNCTION " OR LEFT$(HdrULine, 7) = "CREATE " OR HdrULine = "' GENERATED BY RAPIDP VISUAL IDE" THEN
            FoundSub = 1
        ELSE
            IF LTRIM$(HdrLine) <> "" AND LEFT$(LTRIM$(HdrLine), 1) <> "'" THEN
                UserHeader = UserHeader + HdrLine + NL
            END IF
        END IF
    LOOP
    IF UserHeader <> "" THEN
        Code = Code + UserHeader + NL
    END IF

    ' Generate Form event handlers
    IF FormOnShow <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnShow, "Form1", "OnShow")
    IF FormOnClose <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnClose, "Form1", "OnClose")
    IF FormOnResize <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnResize, "Form1", "OnResize")
    IF FormOnClick <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnClick, "Form1", "OnClick")
    IF FormOnKeyDown <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnKeyDown, "Form1", "OnKeyDown")
    IF FormOnKeyPress <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnKeyPress, "Form1", "OnKeyPress")
    IF FormOnKeyUp <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnKeyUp, "Form1", "OnKeyUp")
    IF FormOnMouseDown <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnMouseDown, "Form1", "OnMouseDown")
    IF FormOnMouseMove <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnMouseMove, "Form1", "OnMouseMove")
    IF FormOnMouseUp <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnMouseUp, "Form1", "OnMouseUp")
    IF FormOnPaint <> "" THEN Code = Code + GenerateSubCode(ExistingCode, FormOnPaint, "Form1", "OnPaint")

    ' Generate component event handlers
    FOR I = 1 TO DesignSurface.CompCount
        IF EvtOnClick(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnClick(I), DesignSurface.GetName(I - 1), "OnClick")
        IF EvtOnDblClick(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnDblClick(I), DesignSurface.GetName(I - 1), "OnDblClick")
        IF EvtOnChange(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnChange(I), DesignSurface.GetName(I - 1), "OnChange")
        IF EvtOnMouseDown(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnMouseDown(I), DesignSurface.GetName(I - 1), "OnMouseDown")
        IF EvtOnMouseMove(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnMouseMove(I), DesignSurface.GetName(I - 1), "OnMouseMove")
        IF EvtOnMouseUp(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnMouseUp(I), DesignSurface.GetName(I - 1), "OnMouseUp")
        IF EvtOnKeyDown(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnKeyDown(I), DesignSurface.GetName(I - 1), "OnKeyDown")
        IF EvtOnKeyPress(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnKeyPress(I), DesignSurface.GetName(I - 1), "OnKeyPress")
        IF EvtOnKeyUp(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnKeyUp(I), DesignSurface.GetName(I - 1), "OnKeyUp")
        IF EvtOnTimer(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnTimer(I), DesignSurface.GetName(I - 1), "OnTimer")
        IF EvtOnPaint(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnPaint(I), DesignSurface.GetName(I - 1), "OnPaint")
        IF EvtOnConnect(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnConnect(I), DesignSurface.GetName(I - 1), "OnConnect")
        IF EvtOnDisconnect(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnDisconnect(I), DesignSurface.GetName(I - 1), "OnDisconnect")
        IF EvtOnError(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnError(I), DesignSurface.GetName(I - 1), "OnError")
        IF EvtOnQueryDone(I) <> "" THEN Code = Code + GenerateSubCode(ExistingCode, EvtOnQueryDone(I), DesignSurface.GetName(I - 1), "OnQueryDone")
    NEXT I

    ' Generate CREATE Form1
    Code = Code + "CREATE Form1 AS PFORM" + NL
    Code = Code + "    Caption = " + CHR$(34) + "Form1" + CHR$(34) + NL
    Code = Code + "    Width = " + STR$(DESIGN_W) + NL
    Code = Code + "    Height = " + STR$(DESIGN_H) + NL
    Code = Code + "    Center" + NL
    IF FormOnShow <> "" THEN Code = Code + "    OnShow = " + FormOnShow + NL
    IF FormOnClose <> "" THEN Code = Code + "    OnClose = " + FormOnClose + NL
    IF FormOnResize <> "" THEN Code = Code + "    OnResize = " + FormOnResize + NL
    IF FormOnClick <> "" THEN Code = Code + "    OnClick = " + FormOnClick + NL
    IF FormOnKeyDown <> "" THEN Code = Code + "    OnKeyDown = " + FormOnKeyDown + NL
    IF FormOnKeyPress <> "" THEN Code = Code + "    OnKeyPress = " + FormOnKeyPress + NL
    IF FormOnKeyUp <> "" THEN Code = Code + "    OnKeyUp = " + FormOnKeyUp + NL
    IF FormOnMouseDown <> "" THEN Code = Code + "    OnMouseDown = " + FormOnMouseDown + NL
    IF FormOnMouseMove <> "" THEN Code = Code + "    OnMouseMove = " + FormOnMouseMove + NL
    IF FormOnMouseUp <> "" THEN Code = Code + "    OnMouseUp = " + FormOnMouseUp + NL
    IF FormOnPaint <> "" THEN Code = Code + "    OnPaint = " + FormOnPaint + NL

    FOR I = 0 TO DesignSurface.CompCount - 1
        CT = DesignSurface.GetType(I)
        CName = DesignSurface.GetName(I)
        Code = Code + "    CREATE " + CName + " AS " + CT + NL

        IF CT <> "PTIMER" AND CT <> "PMYSQL" AND CT <> "PSQLITE" THEN
            Code = Code + "        Left = " + STR$(DesignSurface.GetCompX(I)) + NL
            Code = Code + "        Top = " + STR$(DesignSurface.GetCompY(I)) + NL
            Code = Code + "        Width = " + STR$(DesignSurface.GetCompW(I)) + NL
            Code = Code + "        Height = " + STR$(DesignSurface.GetCompH(I)) + NL
        END IF

        IF CT = "PBUTTON" OR CT = "PLABEL" OR CT = "PCHECKBOX" OR CT = "PRADIOBUTTON" OR CT = "PGROUPBOX" OR CT = "PPANEL" THEN
            DIM CaptVal AS STRING
            CaptVal = DesignSurface.GetProp(I, "caption")
            IF CaptVal <> "" THEN Code = Code + "        Caption = " + CHR$(34) + CaptVal + CHR$(34) + NL
        END IF

        DIM AlnVal AS STRING
        AlnVal = DesignSurface.GetProp(I, "alignment")
        IF AlnVal <> "" AND AlnVal <> "0" THEN
            Code = Code + "        Alignment = " + AlnVal + NL
        END IF

        DIM ChkedVal AS STRING
        ChkedVal = DesignSurface.GetProp(I, "checked")
        IF UCASE$(ChkedVal) = "TRUE" OR ChkedVal = "1" OR ChkedVal = "-1" THEN
            Code = Code + "        Checked = True" + NL
        END IF

        DIM ColVal AS STRING
        ColVal = DesignSurface.GetProp(I, "color")
        IF ColVal <> "" AND ColVal <> "0" THEN
            Code = Code + "        Color = " + ColVal + NL
        END IF

        DIM BdrVal AS STRING
        BdrVal = DesignSurface.GetProp(I, "borderstyle")
        IF BdrVal <> "" AND BdrVal <> "1" THEN
            Code = Code + "        BorderStyle = " + BdrVal + NL
        END IF

        DIM FNVal AS STRING
        DIM FSVal AS STRING
        DIM FBVal AS STRING
        DIM FCVal AS STRING
        FNVal = DesignSurface.GetProp(I, "font.name")
        FSVal = DesignSurface.GetProp(I, "font.size")
        FBVal = DesignSurface.GetProp(I, "font.bold")
        FCVal = DesignSurface.GetProp(I, "fontcolor")
        IF FNVal <> "" THEN Code = Code + "        Font.Name = " + CHR$(34) + FNVal + CHR$(34) + NL
        IF FSVal <> "" AND FSVal <> "0" THEN Code = Code + "        Font.Size = " + FSVal + NL
        IF FBVal <> "" AND FBVal <> "0" AND UCASE$(FBVal) <> "FALSE" THEN Code = Code + "        Font.Bold = " + FBVal + NL
        IF FCVal <> "" AND FCVal <> "0" THEN Code = Code + "        FontColor = " + FCVal + NL

        DIM RDVal2 AS STRING
        RDVal2 = DesignSurface.GetProp(I, "readonly")
        IF UCASE$(RDVal2) = "TRUE" OR RDVal2 = "1" THEN
            Code = Code + "        ReadOnly = True" + NL
        END IF

        DIM WrpVal AS STRING
        WrpVal = DesignSurface.GetProp(I, "wordwrap")
        IF UCASE$(WrpVal) = "TRUE" OR WrpVal = "1" THEN
            Code = Code + "        WordWrap = True" + NL
        END IF

        IF CT = "PTIMER" THEN
            DIM IntVal AS STRING
            IntVal = DesignSurface.GetProp(I, "interval")
            IF IntVal <> "" THEN Code = Code + "        Interval = " + IntVal + NL
            Code = Code + "        Enabled = True" + NL
        END IF

        IF CT = "PMYSQL" THEN
            Code = Code + "        Host = " + CHR$(34) + DesignSurface.GetProp(I, "host") + CHR$(34) + NL
            Code = Code + "        User = " + CHR$(34) + DesignSurface.GetProp(I, "user") + CHR$(34) + NL
            Code = Code + "        Password = " + CHR$(34) + DesignSurface.GetProp(I, "password") + CHR$(34) + NL
            Code = Code + "        Port = " + DesignSurface.GetProp(I, "port") + NL
        END IF

        IF CT = "PSQLITE" THEN
            Code = Code + "        DB = " + CHR$(34) + DesignSurface.GetProp(I, "db") + CHR$(34) + NL
        END IF

        IF CT = "PTRACKBAR" THEN
            DIM TMin AS STRING
            DIM TMax AS STRING
            DIM TPos AS STRING
            TMin = DesignSurface.GetProp(I, "min")
            TMax = DesignSurface.GetProp(I, "max")
            TPos = DesignSurface.GetProp(I, "position")
            IF TMin <> "" AND TMin <> "0" THEN Code = Code + "        Min = " + TMin + NL
            IF TMax <> "" AND TMax <> "100" THEN Code = Code + "        Max = " + TMax + NL
            IF TPos <> "" AND TPos <> "0" THEN Code = Code + "        Position = " + TPos + NL
        END IF

        DIM SI AS INTEGER
        SI = I + 1
        IF EvtOnClick(SI) <> "" THEN Code = Code + "        OnClick = " + EvtOnClick(SI) + NL
        IF EvtOnDblClick(SI) <> "" THEN Code = Code + "        OnDblClick = " + EvtOnDblClick(SI) + NL
        IF EvtOnChange(SI) <> "" THEN Code = Code + "        OnChange = " + EvtOnChange(SI) + NL
        IF EvtOnMouseDown(SI) <> "" THEN Code = Code + "        OnMouseDown = " + EvtOnMouseDown(SI) + NL
        IF EvtOnMouseMove(SI) <> "" THEN Code = Code + "        OnMouseMove = " + EvtOnMouseMove(SI) + NL
        IF EvtOnMouseUp(SI) <> "" THEN Code = Code + "        OnMouseUp = " + EvtOnMouseUp(SI) + NL
        IF EvtOnKeyDown(SI) <> "" THEN Code = Code + "        OnKeyDown = " + EvtOnKeyDown(SI) + NL
        IF EvtOnKeyPress(SI) <> "" THEN Code = Code + "        OnKeyPress = " + EvtOnKeyPress(SI) + NL
        IF EvtOnKeyUp(SI) <> "" THEN Code = Code + "        OnKeyUp = " + EvtOnKeyUp(SI) + NL
        IF EvtOnTimer(SI) <> "" THEN Code = Code + "        OnTimer = " + EvtOnTimer(SI) + NL
        IF EvtOnPaint(SI) <> "" THEN Code = Code + "        OnPaint = " + EvtOnPaint(SI) + NL
        IF EvtOnConnect(SI) <> "" THEN Code = Code + "        OnConnect = " + EvtOnConnect(SI) + NL
        IF EvtOnDisconnect(SI) <> "" THEN Code = Code + "        OnDisconnect = " + EvtOnDisconnect(SI) + NL
        IF EvtOnError(SI) <> "" THEN Code = Code + "        OnError = " + EvtOnError(SI) + NL
        IF EvtOnQueryDone(SI) <> "" THEN Code = Code + "        OnQueryDone = " + EvtOnQueryDone(SI) + NL

        Code = Code + "    END CREATE" + NL
    NEXT I

    Code = Code + "END CREATE" + NL + NL
    Code = Code + "Form1.ShowModal" + NL
    CodeEditor.Text = Code
    StatusBar.Caption = "Code generated for " + STR$(DesignSurface.CompCount) + " components"
END SUB

' ============================================================
' TOGGLE CODE/DESIGN VIEW
' ============================================================
SUB ToggleCodeView
    IF ShowingCode = 0 THEN
        GenerateCode
        DesignSurface.Hide
        CodeEditor.Visible = 1
        ShowingCode = 1
        StatusBar.Caption = "Code View"
    ELSE
        CodeEditor.Visible = 0
        DesignSurface.Show
        ShowingCode = 0
        StatusBar.Caption = "Design View"
    END IF
END SUB

' ============================================================
' FILE / PROJECT OPERATIONS
' ============================================================
SUB NewProject
    DIM I AS INTEGER
    DesignSurface.ClearAll
    BtnCount = 0 : LblCount = 0 : EdtCount = 0
    ChkCount = 0 : CmbCount = 0 : PnlCount = 0
    RadCount = 0 : LstCount = 0 : GrpCount = 0
    PrgCount = 0 : TmrCount = 0 : RchCount = 0
    CnvCount = 0 : MySqlCount = 0 : SQLiteCount = 0
    TrvCount = 0 : ImgCount = 0 : TrkCount = 0
    SplCount = 0 : SgdCount = 0 : SbxCount = 0
    SelIndex = 0
    FormOnShow = "" : FormOnClose = "" : FormOnResize = "" : FormOnKeyDown = "" : FormOnKeyPress = ""
    FormOnKeyUp = "" : FormOnClick = "" : FormOnMouseDown = "" : FormOnMouseMove = "" : FormOnMouseUp = ""
    FormOnPaint = ""
    FOR I = 1 TO 80
        EvtOnClick(I) = "" : EvtOnDblClick(I) = "" : EvtOnChange(I) = ""
        EvtOnMouseDown(I) = "" : EvtOnMouseMove(I) = "" : EvtOnMouseUp(I) = ""
        EvtOnKeyDown(I) = "" : EvtOnKeyPress(I) = "" : EvtOnKeyUp(I) = ""
        EvtOnTimer(I) = "" : EvtOnPaint(I) = "" : EvtOnEnter(I) = ""
        EvtOnConnect(I) = "" : EvtOnDisconnect(I) = "" : EvtOnError(I) = "" : EvtOnQueryDone(I) = ""
    NEXT I
    ProjectFile = ""
    CodeEditor.Text = ""
    DesignSurface.FormCaption = "Form1"
    DesignSurface.Width = DESIGN_W
    DesignSurface.Height = DESIGN_H
    DesignSurface.Show
    UpdateObjCombo
    FillProperties
    FillEvents
    StatusBar.Caption = "New project created"
END SUB

SUB SaveProject
    GenerateCode
    IF SaveDlg.Execute THEN
        DIM FS AS PFileStream
        FS.Open(SaveDlg.FileName, 1)
        FS.WriteLine(CodeEditor.Text)
        FS.Close
        ProjectFile = SaveDlg.FileName
        StatusBar.Caption = "Saved: " + ProjectFile
    END IF
END SUB

SUB CompileAndRun
    GenerateCode
    DIM FS AS PFileStream
    DIM OutFile AS STRING
    OutFile = "_ide_output.rp"
    FS.Open(OutFile, 1)
    FS.WriteLine(CodeEditor.Text)
    FS.Close

    ErrorList.Clear
    ErrorCount = 0
    ErrorList.Visible = 0

    SHELLWAIT("python3 compile.py _ide_output.rp --json-errors > _ide_errors.json 2>&1")

    DIM ErrFS AS PFileStream
    DIM ErrJSON AS STRING
    ErrJSON = ""
    IF FileExists("_ide_errors.json") THEN
        ErrFS.Open("_ide_errors.json", 0)
        DO WHILE NOT ErrFS.EOF
            ErrJSON = ErrJSON + ErrFS.ReadLine + CHR$(10)
        LOOP
        ErrFS.Close
    END IF

    ErrJSON = TRIM$(ErrJSON)

    IF LEFT$(ErrJSON, 1) = "[" AND LEN(ErrJSON) > 2 THEN
        DIM Pos AS INTEGER
        DIM LineNum AS INTEGER
        DIM Msg AS STRING
        DIM ErrType AS STRING
        DIM HasErrors AS INTEGER
        HasErrors = 0
        Pos = 1
        DO WHILE Pos < LEN(ErrJSON)
            DIM TypePos AS INTEGER
            TypePos = INSTR(Pos, ErrJSON, CHR$(34) + "type" + CHR$(34))
            IF TypePos = 0 THEN EXIT DO

            DIM TypeValPos AS INTEGER
            TypeValPos = INSTR(TypePos + 7, ErrJSON, CHR$(34))
            IF TypeValPos > 0 THEN
                DIM TypeEndPos AS INTEGER
                TypeEndPos = INSTR(TypeValPos + 1, ErrJSON, CHR$(34))
                IF TypeEndPos > 0 THEN
                    ErrType = MID$(ErrJSON, TypeValPos + 1, TypeEndPos - TypeValPos - 1)
                END IF
            END IF

            DIM LinePos AS INTEGER
            LinePos = INSTR(TypePos, ErrJSON, CHR$(34) + "line" + CHR$(34))
            IF LinePos > 0 THEN
                DIM LineValStart AS INTEGER
                LineValStart = INSTR(LinePos + 7, ErrJSON, ":") + 1
                DO WHILE MID$(ErrJSON, LineValStart, 1) = " "
                    LineValStart = LineValStart + 1
                LOOP
                DIM LineValEnd AS INTEGER
                LineValEnd = LineValStart
                DO WHILE LineValEnd <= LEN(ErrJSON) AND INSTR(1, "0123456789", MID$(ErrJSON, LineValEnd, 1)) > 0
                    LineValEnd = LineValEnd + 1
                LOOP
                LineNum = VAL(MID$(ErrJSON, LineValStart, LineValEnd - LineValStart))
            END IF

            DIM MsgPos AS INTEGER
            MsgPos = INSTR(TypePos, ErrJSON, CHR$(34) + "message" + CHR$(34))
            IF MsgPos > 0 THEN
                DIM MsgValPos AS INTEGER
                MsgValPos = INSTR(MsgPos + 11, ErrJSON, CHR$(34))
                IF MsgValPos > 0 THEN
                    DIM MsgEndPos AS INTEGER
                    MsgEndPos = INSTR(MsgValPos + 1, ErrJSON, CHR$(34))
                    IF MsgEndPos > 0 THEN
                        Msg = MID$(ErrJSON, MsgValPos + 1, MsgEndPos - MsgValPos - 1)
                    END IF
                END IF
            END IF

            IF LEN(Msg) > 0 THEN
                DIM Prefix AS STRING
                IF ErrType = "warning" THEN
                    Prefix = "Warning"
                ELSE
                    Prefix = "Error"
                    HasErrors = 1
                END IF
                ErrorList.AddItems("[Line " + STR$(LineNum) + "] " + Prefix + ": " + Msg)
                ErrorCount = ErrorCount + 1
                IF ErrorCount <= 100 THEN
                    ErrorLines(ErrorCount) = LineNum
                END IF
            END IF

            Pos = MsgPos + 10
            IF Pos < 1 THEN EXIT DO
        LOOP

        IF HasErrors = 1 THEN
            ErrorList.Visible = 1
            StatusBar.Caption = STR$(ErrorCount) + " error(s) found. Double-click to jump to line."
        ELSE
            IF ErrorCount > 0 THEN
                ErrorList.Visible = 1
                StatusBar.Caption = STR$(ErrorCount) + " warning(s). Running..."
            END IF
            SHELL("python3 compile.py _ide_output.rp -r")
        END IF
    ELSE
        StatusBar.Caption = "Compiled successfully. Running..."
        SHELL("python3 compile.py _ide_output.rp -r")
    END IF
END SUB

SUB ErrorListClick
    DIM Idx AS INTEGER
    Idx = ErrorList.ItemIndex + 1
    IF Idx >= 1 AND Idx <= ErrorCount THEN
        DIM TargetLine AS INTEGER
        TargetLine = ErrorLines(Idx)
        IF TargetLine > 0 THEN
            IF ShowingCode = 0 THEN
                ToggleCodeView
            END IF
            CodeEditor.GotoLine(TargetLine)
            StatusBar.Caption = "Line " + STR$(TargetLine)
        END IF
    END IF
END SUB

SUB CompileBytecode
    GenerateCode
    DIM FS AS PFileStream
    DIM OutFile AS STRING
    OutFile = "_ide_output.rp"
    FS.Open(OutFile, 1)
    FS.WriteLine(CodeEditor.Text)
    FS.Close
    StatusBar.Caption = "Compiling to bytecode..."
    SHELLWAIT("python3 compile.py _ide_output.rp -b")
    StatusBar.Caption = "Bytecode compilation complete."
END SUB

SUB BuildStandalone
    GenerateCode
    DIM FS AS PFileStream
    DIM OutFile AS STRING
    OutFile = "_ide_output.rp"
    FS.Open(OutFile, 1)
    FS.WriteLine(CodeEditor.Text)
    FS.Close
    StatusBar.Caption = "Building standalone executable (this may take a while)..."
    SHELLWAIT("python3 compile.py _ide_output.rp -s")
    StatusBar.Caption = "Standalone build complete. Check dist/ folder."
END SUB

SUB ExitIDE
    IDE.Close
END SUB

SUB DeleteSelected
    IF SelIndex >= 1 AND SelIndex <= DesignSurface.CompCount THEN
        DIM CI AS INTEGER
        CI = SelIndex - 1
        DesignSurface.RemoveComponent(CI)
        SelIndex = 0
        FillProperties
        FillEvents
        UpdateObjCombo
        StatusBar.Caption = "Component deleted"
    END IF
END SUB

SUB ObjComboChange
    DIM I AS INTEGER
    DIM Sel AS STRING
    Sel = ObjCombo.Text
    IF Sel = "Form1" THEN
        SelIndex = 0
        DesignSurface.SelectComp(-1)
    ELSE
        FOR I = 0 TO DesignSurface.CompCount - 1
            IF DesignSurface.GetName(I) = Sel THEN
                SelIndex = I + 1
                DesignSurface.SelectComp(I)
            END IF
        NEXT I
    END IF
    FillProperties
    FillEvents
END SUB

' ============================================================
' CREATE THE IDE
' ============================================================

CREATE IDE AS PFORM
    Caption = "RapidP Visual IDE"
    Width = 1100
    Height = 800
    Center

    CREATE MainMenu AS PMAINMENU
        CREATE FileMenu AS PMENUITEM
            Caption = "&File"
            CREATE NewItem AS PMENUITEM
                Caption = "&New Project"
                OnClick = NewProject
            END CREATE
            CREATE SaveItem AS PMENUITEM
                Caption = "&Save As..."
                OnClick = SaveProject
            END CREATE
            CREATE ExitItem AS PMENUITEM
                Caption = "E&xit"
                OnClick = ExitIDE
            END CREATE
        END CREATE
        CREATE RunMenu AS PMENUITEM
            Caption = "&Run"
            CREATE CodeItem AS PMENUITEM
                Caption = "Toggle &Code / Design"
                OnClick = ToggleCodeView
            END CREATE
            CREATE RunItem AS PMENUITEM
                Caption = "Compile && &Run"
                OnClick = CompileAndRun
            END CREATE
            CREATE BytecodeItem AS PMENUITEM
                Caption = "Compile to &Bytecode"
                OnClick = CompileBytecode
            END CREATE
            CREATE StandaloneItem AS PMENUITEM
                Caption = "Build &Standalone EXE"
                OnClick = BuildStandalone
            END CREATE
        END CREATE
    END CREATE

    ' === Component Toolbar (3 rows) ===
    CREATE ToolPanel AS PPANEL
        Left = 0 : Top = 0
        Width = 780 : Height = 90
    END CREATE

    ' --- Row 1: Standard controls ---
    CREATE BtnPointer AS PBUTTON
        Caption = "◇ Ptr"
        Left = 4 : Top = 4 : Width = 48 : Height = 26
        OnClick = SetToolPointer
    END CREATE
    CREATE BtnAddLabel AS PBUTTON
        Caption = "🏷 Label"
        Left = 54 : Top = 4 : Width = 58 : Height = 26
        OnClick = SetToolLabel
    END CREATE
    CREATE BtnAddEdit AS PBUTTON
        Caption = "✍ Edit"
        Left = 114 : Top = 4 : Width = 52 : Height = 26
        OnClick = SetToolEdit
    END CREATE
    CREATE BtnAddButton AS PBUTTON
        Caption = "⏺ Btn"
        Left = 168 : Top = 4 : Width = 50 : Height = 26
        OnClick = SetToolButton
    END CREATE
    CREATE BtnAddCheck AS PBUTTON
        Caption = "☑ Chk"
        Left = 220 : Top = 4 : Width = 48 : Height = 26
        OnClick = SetToolCheck
    END CREATE
    CREATE BtnAddCombo AS PBUTTON
        Caption = "▼ Cmb"
        Left = 270 : Top = 4 : Width = 50 : Height = 26
        OnClick = SetToolCombo
    END CREATE
    CREATE BtnAddPanel AS PBUTTON
        Caption = "□ Pnl"
        Left = 322 : Top = 4 : Width = 48 : Height = 26
        OnClick = SetToolPanel
    END CREATE
    CREATE BtnAddRadio AS PBUTTON
        Caption = "◉ Rad"
        Left = 372 : Top = 4 : Width = 48 : Height = 26
        OnClick = SetToolRadio
    END CREATE
    CREATE BtnAddList AS PBUTTON
