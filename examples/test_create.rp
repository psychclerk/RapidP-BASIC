$TYPECHECK ON

CONST MyCaption = "Click Me Now"

CREATE Form1 AS PForm
    Caption = "Main Form"
    Width = 400
    Height = 300
    
    CREATE Btn1 AS PButton
        Caption = MyCaption
        Left = 100
        Top = 100
        Width = 150
    END CREATE
END CREATE

SUB BtnClick()
    PRINT "Button was clicked!"
    Form1.Close()
END SUB

Btn1.OnClick = BtnClick
Form1.ShowModal()
